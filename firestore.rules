rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Public newsletter signups (guest users allowed).
    match /signed_up_emails/{docId} {
      allow create: if request.resource.data.keys().hasOnly(['email', 'timestamp'])
        && request.resource.data.email is string
        && request.resource.data.email.matches('^[^@\s]+@[^@\s]+\.[^@\s]+$');
      allow read, update, delete: if request.auth != null;
    }

    // This allows anyone to read and write chat messages.
    match /chats/{document=**} {
      allow read, write: if true;
    }

    // Support tickets can be created by anyone (including guests).
    match /support_tickets/{document=**} {
      allow read, write: if true;
    }

    // Device click tracking can be written by anyone.
    match /device_clicks/{document=**} {
      allow write: if true;
      allow read: if request.auth != null;
    }

    // Default policy for all other collections.
    match /{document=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }
  }
}
