{
  "name": "buybacking",
  "version": "1.0.0",
  "description": "BuyBack project.",
  "main": "index.js",
  "scripts": {
    "start": "npm run dev",
    "dev": "sh -c 'npm run watch:site-css & npm run watch:admin-css & node server.js'",
    "serve": "node server.js",
    "test": "echo \"Error: no test specified\" && exit 1",
    "build": "npm run build:site-css && npm run build:admin-css",
    "watch:site-css": "tailwindcss -c tailwind.config.js -i assets/css/input.css -o assets/css/tailwind.css --watch",
    "watch:admin-css": "tailwindcss -c admin/tailwind.config.js -i admin/tailwind.css -o assets/css/admin-tailwind.css --watch",
    "build:admin-css": "tailwindcss -c admin/tailwind.config.js -i admin/tailwind.css -o assets/css/admin-tailwind.css --minify",
    "check:no-functions": "node tools/check-no-functions.js",
    "convert:misnamed-webp": "node tools/convert-misnamed-webp.js",
    "build:site-css": "tailwindcss -c tailwind.config.js -i assets/css/input.css -o assets/css/tailwind.css --minify"
  },
  "devDependencies": {
    "autoprefixer": "^10.4.21",
    "lighthouse": "^12.8.2",
    "postcss": "^8.5.6",
    "sharp": "^0.33.5",
    "tailwindcss": "^3.4.18"
  },
  "dependencies": {
    "axios": "^1.11.0",
    "bwip-js": "^4.8.0",
    "cors": "^2.8.6",
    "csv-parse": "^6.1.0",
    "dotenv": "^16.6.1",
    "express": "^5.2.1",
    "express-rate-limit": "^7.5.1",
    "fast-xml-parser": "^5.3.4",
    "firebase-functions": "^6.6.0",
    "mongodb": "^6.21.0",
    "nodemailer": "^7.0.13",
    "pdf-lib": "^1.17.1",
    "pg": "^8.18.0",
    "puppeteer": "^24.27.0",
    "puppeteer-extra": "^3.3.6",
    "puppeteer-extra-plugin-stealth": "^2.11.2",
    "serverless-http": "^3.2.0",
    "shipengine": "^1.0.7",
    "stripe": "^20.3.0",
    "xmlbuilder2": "^4.0.0"
  }
}
